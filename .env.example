# Copy this file to .env.local (gitignored) and fill in the values.
# All VITE_* vars are baked into the bundle at build time.

# --- Firebase web app config (public; from Firebase console → Project settings) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# --- Pre-launch gate ---
# false = show the "Coming soon" holding page to the public; allowlisted users can
#         sign in to preview the real site. true = site is fully public (gate off).
VITE_LAUNCHED=false
# Comma-separated emails allowed to preview the site while VITE_LAUNCHED=false.
VITE_PREVIEW_ALLOWLIST=you@example.com

# --- Analytics ---
# GA4 measurement ID (G-XXXXXXXXXX). Leave blank to disable analytics entirely.
# GA is consent-gated: it only loads after a visitor accepts the cookie banner.
VITE_GA_MEASUREMENT_ID=
