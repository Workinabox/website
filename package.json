{
  "name": "wiab-website",
  "version": "0.1.0",
  "description": "The Workinabox public marketing website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "firebase deploy",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "format": "prettier --write ."
  },
  "author": "Gos & co ApS",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react-swc": "4.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.3.5",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "firebase": "^12.14.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0"
  },
  "engines": {
    "node": "22.x"
  }
}
